# Base de données PostgreSQL (Neon, Supabase, Railway, ou serveur local)
DATABASE_URL="postgresql://user:password@localhost:5432/route67?schema=public"

# Clé secrète utilisée pour signer les jetons de session (JWT).
# Génère une valeur forte, par ex. avec : openssl rand -base64 32
JWT_SECRET="remplace-moi-par-une-longue-valeur-aleatoire"

# URL publique du site (utile pour les liens dans les emails plus tard)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Clé API Anthropic (Claude) — active l'assistant IA candidat et la
# pré-rédaction d'actualités dans l'espace admin. Sans cette clé, ces
# fonctionnalités répondent avec un message clair au lieu de planter le
# reste du site. Génère une clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Numéro Mobile Money (Orange Money / MTN MoMo) à afficher aux utilisateurs
# qui demandent un passage à un forfait payant (voir README, section
# "Paiement Mobile Money").
MOMO_ORANGE_NUMBER="695714320"
MOMO_MTN_NUMBER="680090483"
# Nom affiché comme titulaire des comptes Mobile Money ci-dessus, pour que
# la personne vérifie qu'elle paie au bon destinataire.
MOMO_ACCOUNT_NAME="Verdier Fofack"

# Lien de don PayPal (ex. https://paypal.me/route67) — pour les contributeurs
# hors zone Mobile Money.
PAYPAL_LINK="fofackverdier@yahoo.com"

# Clé API Resend (https://resend.com) — active l'envoi réel des emails
# (instructions de paiement Premium, notification des messages de contact).
# Sans cette clé, le message est quand même enregistré en base (visible
# dans /admin) et affiché à l'écran — rien ne se perd, l'email en plus.
RESEND_API_KEY=""
# Adresse d'expédition (doit être un domaine vérifié sur Resend en prod ;
# "onboarding@resend.dev" fonctionne pour les tests).
EMAIL_FROM="Route 67 <onboarding@resend.dev>"

# Adresse email et numéro WhatsApp (format international, ex. 237600000000)
# de l'équipe — utilisés pour la page /contact et la confirmation manuelle
# des paiements Mobile Money.
ADMIN_CONTACT_EMAIL="contact@route67.app"
ADMIN_WHATSAPP_NUMBER=""

# Liens réseaux sociaux affichés en pied de page (tous optionnels).
SOCIAL_FACEBOOK_URL=""
SOCIAL_INSTAGRAM_URL=""
SOCIAL_LINKEDIN_URL=""
SOCIAL_TIKTOK_URL="https://www.tiktok.com/@replaydumonde"
